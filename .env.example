# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/arxiv_assistant

# Application
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# Auth (development only — returns magic link in API response)
ALLOW_DEV_MAGIC_LINK_RESPONSE=1

# Email (required in production when ALLOW_DEV_MAGIC_LINK_RESPONSE is unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=

# Internal cron worker → API authentication
INTERNAL_CRON_TOKEN=

# Optional: comma-separated admin emails for debug routes
DEBUG_ADMIN_EMAILS=
ALLOW_DEBUG_FEATURES=0

# Set to 1 only when running behind a trusted reverse proxy
TRUST_PROXY_HEADERS=0

# Pipeline tuning
ARXIV_CATEGORIES=cs.AI
INGESTION_MAX_RESULTS=150
EMBEDDING_LIMIT=600

# Rate limits (database-backed automatically when APP_ENV=production)
RATE_LIMIT_WINDOW_SECONDS=3600
DAILY_PICKS_GENERATE_LIMIT_PER_USER=5
MAGIC_LINK_REQUEST_LIMIT_PER_EMAIL=3
MAGIC_LINK_REQUEST_LIMIT_PER_IP=20
MAGIC_LINK_VERIFY_LIMIT_PER_IP=30
# RATE_LIMIT_USE_DATABASE=1
