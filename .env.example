# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/arxiv_assistant

# Application
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# Auth (development only — returns magic link in API response)
ALLOW_DEV_MAGIC_LINK_RESPONSE=1

# Email (required in production when ALLOW_DEV_MAGIC_LINK_RESPONSE is unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=

# Internal cron worker → API authentication
INTERNAL_CRON_TOKEN=

# Optional: comma-separated admin emails for debug routes
DEBUG_ADMIN_EMAILS=
ALLOW_DEBUG_FEATURES=0

# Set to 1 only when running behind a trusted reverse proxy
TRUST_PROXY_HEADERS=0
