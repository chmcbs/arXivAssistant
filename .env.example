# Copy to .env for local development. On the server, create .env with production values only.

# --- Application ---
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# --- Database (local docker-compose exposes 5433) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/arxiv_assistant

# --- Auth (development only — returns magic link in API response) ---
# In production (APP_ENV=production): must be unset or 0. Prod compose sets this to 0.
ALLOW_DEV_MAGIC_LINK_RESPONSE=1

# --- Email (required in production) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
# SMTP_USE_SSL=1

# --- Internal cron worker → API ---
INTERNAL_CRON_TOKEN=

# --- Debug (optional; keep off in production) ---
DEBUG_ADMIN_EMAILS=
ALLOW_DEBUG_FEATURES=0
# ALLOW_DEBUG_DIGEST_DATA_RESET=0

# --- Reverse proxy (set 1 when behind Caddy/nginx you control) ---
TRUST_PROXY_HEADERS=0

# --- Pipeline tuning ---
ARXIV_CATEGORIES=cs.AI
INGESTION_MAX_RESULTS=150
EMBEDDING_LIMIT=600
DAILY_PICKS_K=3
KEYWORD_BOOST_CAP=0.25

# --- Rate limits (database-backed when APP_ENV=production) ---
RATE_LIMIT_WINDOW_SECONDS=3600
DAILY_PICKS_GENERATE_LIMIT_PER_USER=5
MAGIC_LINK_REQUEST_LIMIT_PER_EMAIL=3
MAGIC_LINK_REQUEST_LIMIT_PER_IP=20
MAGIC_LINK_VERIFY_LIMIT_PER_IP=30
# RATE_LIMIT_USE_DATABASE=1

# --- Worker (docker-compose) ---
CRON_INTERVAL_SECONDS=86400

# --- Production-only (docker-compose.prod.yml) ---
# POSTGRES_PASSWORD=change-me
# APP_BASE_URL=https://your-domain.com

# --- Do not set in production ---
# DISABLE_CSRF=1
# DISABLE_RATE_LIMIT=1

# --- CLI / scripts only (not used by authenticated API routes) ---
# DEFAULT_USER_ID=default
